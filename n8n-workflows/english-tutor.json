        "additionalFields": {}
      },
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [500, 0],
      "id": "27d27a8a-7863-420c-a325-4b2bc515fc22",
      "name": "Send Message"
    }
  ],
  "connections": {
    "Telegram Trigger": {
